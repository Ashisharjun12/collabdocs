<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Inter', Arial, sans-serif; background-color: #f4f7f6; margin: 0; padding: 20px; }
        .card { background: white; max-width: 500px; margin: 0 auto; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        .header { background: #1D9E75; color: white; padding: 30px; text-align: center; }
        .content { padding: 30px; color: #333; line-height: 1.6; }
        .footer { padding: 20px; text-align: center; font-size: 12px; color: #888; }
        .btn { display: inline-block; background: #1D9E75; color: white !important; text-decoration: none; padding: 12px 24px; border-radius: 8px; font-weight: bold; margin-top: 20px; }
        .logo-circle { width: 60px; height: 60px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; font-size: 24px; font-weight: bold; color: #1D9E75; }
    </style>
</head>
<body>
    <div class="card">
        <div class="header">
            <div class="logo-circle"><%= workspaceName.charAt(0).toUpperCase() %></div>
            <h1>Workspace Invitation</h1>
        </div>
        <div class="content">
            <p>Hello,</p>
            <p><strong><%= inviterName %></strong> has invited you to join the <strong><%= workspaceName %></strong> workspace on CollabDocs.</p>
            <p>As a <strong><%= role %></strong>, you'll be able to collaborate on documents, share ideas, and work together in real-time.</p>
            <div style="text-align: center;">
                <a href="<%= inviteUrl %>" class="btn">Join Workspace</a>
            </div>
            <p style="margin-top: 30px; font-size: 13px; color: #666;">
                If you didn't expect this invitation, you can safely ignore this email.
            </p>
        </div>
        <div class="footer">
            &copy; 2026 CollabDocs. All rights reserved.
        </div>
    </div>
</body>
</html>
