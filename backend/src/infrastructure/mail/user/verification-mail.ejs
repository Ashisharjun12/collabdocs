<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Your Email — CollabDocs</title>
</head>
<body style="margin:0;padding:0;background-color:#0f1117;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">

  <!-- WRAPPER -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0f1117;padding:40px 16px;">
    <tr>
      <td align="center">

        <!-- CARD -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:520px;background-color:#13151f;border-radius:16px;border:1px solid #1e2130;overflow:hidden;">

          <!-- TOP ACCENT BAR -->
          <tr>
            <td style="height:4px;background-color:#1D9E75;"></td>
          </tr>

          <!-- HEADER -->
          <tr>
            <td align="center" style="padding:32px 40px 24px;">
              <!-- LOGO -->
              <table cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="background-color:#1D9E75;border-radius:8px;width:36px;height:36px;text-align:center;vertical-align:middle;">
                    <span style="color:#ffffff;font-size:18px;font-weight:700;line-height:36px;">C</span>
                  </td>
                  <td style="padding-left:10px;vertical-align:middle;">
                    <span style="font-size:20px;font-weight:500;color:#e2e8f0;letter-spacing:-0.3px;">Collab<span style="color:#1D9E75;">Docs</span></span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ICON -->
          <tr>
            <td align="center" style="padding:0 40px 20px;">
              <table cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="width:64px;height:64px;background-color:#0F6E56;border-radius:50%;border:2px solid #1D9E75;text-align:center;vertical-align:middle;">
                    <span style="font-size:28px;line-height:64px;">✉️</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- MAIN CONTENT -->
          <tr>
            <td style="padding:0 40px 28px;">

              <!-- GREETING -->
              <h1 style="margin:0 0 8px;font-size:22px;font-weight:500;color:#e2e8f0;text-align:center;letter-spacing:-0.3px;">
                welcome, <%= name %>! 👋
              </h1>
              <p style="margin:0 0 24px;font-size:14px;color:#64748b;text-align:center;line-height:1.7;">
                thanks for signing up. one last step — verify your email address to activate your CollabDocs account.
              </p>

              <!-- DIVIDER -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td style="height:1px;background-color:#1e2130;"></td>
                </tr>
              </table>

              <!-- VERIFY BUTTON -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
                <tr>
                  <td align="center">
                    <a href="<%= url %>"
                       style="display:inline-block;background-color:#1D9E75;color:#ffffff;text-decoration:none;font-size:14px;font-weight:500;padding:13px 36px;border-radius:8px;letter-spacing:0.2px;">
                      verify my email →
                    </a>
                  </td>
                </tr>
              </table>

              <!-- EXPIRY NOTE -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td align="center">
                    <span style="font-size:12px;color:#475569;">⏰ &nbsp;this link expires in <strong style="color:#94a3b8;">24 hours</strong></span>
                  </td>
                </tr>
              </table>

              <!-- DIVIDER -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
                <tr>
                  <td style="height:1px;background-color:#1e2130;"></td>
                </tr>
              </table>

              <!-- FALLBACK LINK BOX -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="background-color:#0a0c12;border-radius:8px;border:1px solid #1e2130;padding:14px 16px;">
                    <p style="margin:0 0 6px;font-size:12px;color:#475569;">
                      button not working? copy and paste this link into your browser:
                    </p>
                    <p style="margin:0;font-size:11px;color:#1D9E75;word-break:break-all;line-height:1.6;">
                      <%= url %>
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- WHAT HAPPENS NEXT -->
          <tr>
            <td style="padding:0 40px 28px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0a0c12;border-radius:10px;border:1px solid #1e2130;padding:16px;">
                <tr>
                  <td style="padding:16px;">
                    <p style="margin:0 0 12px;font-size:12px;font-weight:500;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;">what happens next</p>
                    <!-- STEP 1 -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:10px;">
                      <tr>
                        <td style="width:24px;vertical-align:top;padding-top:1px;">
                          <span style="display:inline-block;width:20px;height:20px;background-color:#0F6E56;border-radius:50%;text-align:center;font-size:11px;color:#9FE1CB;line-height:20px;font-weight:500;">1</span>
                        </td>
                        <td style="padding-left:10px;">
                          <span style="font-size:13px;color:#94a3b8;">click verify and your account gets activated instantly</span>
                        </td>
                      </tr>
                    </table>
                    <!-- STEP 2 -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:10px;">
                      <tr>
                        <td style="width:24px;vertical-align:top;padding-top:1px;">
                          <span style="display:inline-block;width:20px;height:20px;background-color:#0F6E56;border-radius:50%;text-align:center;font-size:11px;color:#9FE1CB;line-height:20px;font-weight:500;">2</span>
                        </td>
                        <td style="padding-left:10px;">
                          <span style="font-size:13px;color:#94a3b8;">create your first document or invite your team</span>
                        </td>
                      </tr>
                    </table>
                    <!-- STEP 3 -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="width:24px;vertical-align:top;padding-top:1px;">
                          <span style="display:inline-block;width:20px;height:20px;background-color:#0F6E56;border-radius:50%;text-align:center;font-size:11px;color:#9FE1CB;line-height:20px;font-weight:500;">3</span>
                        </td>
                        <td style="padding-left:10px;">
                          <span style="font-size:13px;color:#94a3b8;">collaborate in real-time with your workspace</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background-color:#0d0f18;border-top:1px solid #1e2130;padding:20px 40px;text-align:center;">
              <p style="margin:0 0 6px;font-size:12px;color:#475569;">
                you're receiving this because you signed up at
                <a href="https://collabdocs.io" style="color:#1D9E75;text-decoration:none;">collabdocs.io</a>
              </p>
              <p style="margin:0 0 6px;font-size:12px;color:#475569;">
                if you didn't create an account, you can safely ignore this email.
              </p>
              <p style="margin:0;font-size:11px;color:#2a2d3a;">
                © 2026 CollabDocs · made with ♥ in India
              </p>
            </td>
          </tr>

        </table>
        <!-- END CARD -->

      </td>
    </tr>
  </table>

</body>
</html>
