
# APP CONFIG 
NODE_ENV=production
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:80
RATE_LIMIT_ENABLED=false

# DATABASE (Postgres)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=collabdocs

POSTGRES_DATABASE_URL=postgresql://postgres:password@db:5432/collabdocs

# REDIS (Cache & Queues)
REDIS_DATABASE_URI=redis://redis:6379

#  AUTHENTICATION 
JWT_SECRET=your_super_secret_jwt_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# GOOGLE OAUTH
# Create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

#  CLOUDFLARE R2 (Action Required)
# Create at https://dash.cloudflare.com/
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_DOMAIN=https://pub-your-id.r2.dev

# EMAIL (Resend) (Action Required)
# Create at https://resend.com/
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=onboarding@resend.dev

# FRONTEND (Vite) 
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
